    {"id": "python", "name": "Python", "family": "scripting", "paradigm": "multi", "extract_method": "introspect", "toolchain": "python", "extract_target": "stdlib + popular pip packages", "doc_url": "https://docs.python.org/3/library/", "implemented": true, "extractor": "python_via_inspect"},
