{
  "name": "amni-adam",
  "displayName": "Adam (Amni-Ai) — local code assistant",
  "description": "Local-first AI coding assistant — connects to your running Adam server. Inline completions, chat, agentic build tasks, all on-device.",
  "version": "0.1.0",
  "publisher": "amnibro",
  "license": "CC-BY-NC-4.0",
  "engines": {"vscode": "^1.80.0"},
  "categories": ["AI", "Programming Languages", "Snippets"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {"command": "adam.ask", "title": "Adam: Ask"},
      {"command": "adam.complete", "title": "Adam: Inline Complete at Cursor"},
      {"command": "adam.build", "title": "Adam: Agentic Build (selected text as goal)"},
      {"command": "adam.health", "title": "Adam: Show Server Health"}
    ],
    "configuration": {
      "title": "Adam",
      "properties": {
        "adam.host": {"type": "string", "default": "127.0.0.1", "description": "Adam server host"},
        "adam.port": {"type": "number", "default": 11434, "description": "Adam server port"},
        "adam.inlineCompletion": {"type": "boolean", "default": true, "description": "Enable inline completion provider"},
        "adam.completionMaxTokens": {"type": "number", "default": 30, "description": "Max tokens for inline completions"},
        "adam.persona": {"type": "string", "default": "Rikku", "description": "Adam persona for chat (Rikku/Yoda/Mentor/Scientist/etc)"}
      }
    },
    "keybindings": [
      {"command": "adam.ask", "key": "ctrl+alt+a", "mac": "cmd+alt+a"},
      {"command": "adam.complete", "key": "ctrl+alt+space", "mac": "cmd+alt+space"}
    ]
  }
}
